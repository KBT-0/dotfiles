# .zshrc

if [ -d "$HOME/.local/bin" ]; then
    path=("$HOME/.local/bin" $path)
fi

if [ -d "$HOME/bin" ]; then
    path=("$HOME/bin" $path)
fi

# Homebrew defaults on Apple Silicon and Intel macOS.
if [ -d /opt/homebrew/bin ]; then
    path=(/opt/homebrew/bin $path)
fi

if [ -d /usr/local/bin ]; then
    path=(/usr/local/bin $path)
fi

export PATH

if [ -r "$HOME/.config/shell/lfcd.sh" ]; then
    . "$HOME/.config/shell/lfcd.sh"
fi

# Oh My Posh prompt - same atomic theme used by the Windows PowerShell profile.
if command -v oh-my-posh >/dev/null 2>&1; then
    eval "$(oh-my-posh init zsh --config atomic)"
fi

# inshellisense must stay last so its shell runtime can own the suggestion UI.
[[ -f ~/.inshellisense/init/zsh/init.zsh ]] && source ~/.inshellisense/init/zsh/init.zsh

# zsh-autosuggestions: inline grey suggestions from history (→ to accept)
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
bindkey '^[[Z' autosuggest-accept  # Shift+Tab to accept full suggestion

# zsh-history-substring-search: type prefix + ↑/↓ to walk through matching history
source $(brew --prefix)/share/zsh-history-substring-search/zsh-history-substring-search.zsh
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

# Larger history file + share between sessions
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_REDUCE_BLANKS
